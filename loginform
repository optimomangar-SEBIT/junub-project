from PyQt5.QtWidgets import QWidget, QMessageBox
from PyQt5.QtCore import QTimer
from junubi import Ui_junubilogin_Form


class LoginPage(QWidget):
    def __init__(self, stack, main):
        super().__init__()
        self.stack = stack
        self.main = main

        self.ui = Ui_junubilogin_Form()
        self.ui.setupUi(self)

        # ---------------- SIGNALS ----------------
        self.ui.login_pushButton.clicked.connect(self.login)
        self.ui.loginclear_pushButton.clicked.connect(self.clear)

        self.ui.position_comboBox.addItems(["ADMIN","BURSAR","TEACHER"])

        # Press Enter to login
        self.ui.loginpassword_lineEdit.returnPressed.connect(self.login)

        # ---------------- STYLE ----------------
        self.setStyleSheet("""
            QLineEdit {
                padding: 6px;
                border: 1px solid gray;
                border-radius: 5px;
            }
            QPushButton {
                background-color: blue;
                border: 1px solid gray;
                padding: 8px;
                border-radius: 5px;
            }
            QPushButton:hover {
                background-color: #2980b9;
                color: white;
            }
        """)

    # ---------------- LOGIN FUNCTION ----------------
    def login(self):
        username = self.ui.loginname_lineEdit.text().strip()
        position = self.ui.position_comboBox.currentText()
        password = self.ui.loginpassword_lineEdit.text().strip()

        self.stack.setCurrentIndex(1)  # Go to dashboard
        self.main.enable_navigation()

         # Highlight dashboard
        self.main.highlighted_sidebar_index = 0
        self.main.update_sidebar_highlight()

        # DELAY LOADING
        QTimer.singleShot(200, self.refresh_pages)

        self.clear()


    # REFRESH DATA PAGES
    def refresh_pages(self):
        try:
            self.main.dashboard.load_statistics()
            self.main.results.load_data()
            self.main.fees.load_data()

        except Exception as e:
            print("Refresh error:", e)


    # ---------------- CLEAR FUNCTION ----------------
    def clear(self):
        self.ui.loginname_lineEdit.clear()
        self.ui.loginpassword_lineEdit.clear()
